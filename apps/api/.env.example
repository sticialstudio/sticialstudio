# API Environment Variables
# Copy this file to .env for local development or configure equivalents in Render.

# Database
# Local monorepo default:
DATABASE_URL="file:../../packages/database/prisma/dev.db"
# Render with a persistent disk can use a path like:
# DATABASE_URL="file:/var/data/dev.db"

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# Supabase Google OAuth handoff
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server
PORT=4000
NODE_ENV=development

# Optional Linux/Render Arduino CLI settings.
# If you use the Render startup bootstrap in this repo, these defaults are applied automatically.
# Override them only if you want a different persistent location or CLI version.
# ARDUINO_CLI_PATH=/var/data/arduino-cli/bin/arduino-cli
# ARDUINO_DIRECTORIES_DATA=/var/data/arduino-cli/data
# ARDUINO_DIRECTORIES_DOWNLOADS=/var/data/arduino-cli/staging
# ARDUINO_DIRECTORIES_USER=/var/data/arduino-cli/user
# ARDUINO_CORE_PACKAGE=arduino:avr
# ARDUINO_CLI_VERSION=latest
