# API Environment Variables
# Copy this file to .env for local development or configure equivalents in Render.

# Database
# Local monorepo default:
DATABASE_URL="file:../../packages/database/prisma/dev.db"
# Render with a persistent disk can use a path like:
# DATABASE_URL="file:/var/data/dev.db"

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# Supabase Google OAuth handoff
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server
PORT=4000
NODE_ENV=development

# Optional: set this on Linux/Render only if you install a compatible arduino-cli binary there.
# Without it, Arduino compile/library routes return a truthful 503 in deployed environments.
# ARDUINO_CLI_PATH=/usr/local/bin/arduino-cli

